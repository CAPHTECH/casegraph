{
  "name": "casegraph",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "pretest:e2e": "pnpm build",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:analysis-golden": "vitest run tests/analysis-golden.test.ts",
    "test:analysis-eval": "vitest run tests/analysis-eval.test.ts",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "cg": "NODE_NO_WARNINGS=1 node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^24.5.2",
    "fast-check": "^3.22.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
