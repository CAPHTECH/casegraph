{
  "name": "@caphtech/casegraph-core",
  "version": "0.1.0",
  "private": false,
  "description": "Deterministic core for CaseGraph: replay, validation, frontier, patch, and analysis.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./experimental": {
      "types": "./dist/experimental.d.ts",
      "import": "./dist/experimental.js"
    },
    "./plugin-server": {
      "types": "./dist/plugin-server.d.ts",
      "import": "./dist/plugin-server.js"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "README.md"
  ],
  "homepage": "https://github.com/CAPHTECH/casegraph",
  "bugs": {
    "url": "https://github.com/CAPHTECH/casegraph/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CAPHTECH/casegraph.git",
    "directory": "packages/core"
  },
  "keywords": [
    "casegraph",
    "workflow",
    "graph",
    "deterministic",
    "planning"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ulid": "^2.4.0",
    "yaml": "^2.8.1"
  }
}
