{
  "name": "@caphtech/casegraph-kernel",
  "version": "0.1.0",
  "private": false,
  "description": "Pure CaseGraph kernel: graph logic, validation, reducer, and analysis.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./experimental": {
      "types": "./dist/experimental.d.ts",
      "import": "./dist/experimental.js"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "README.md"
  ],
  "homepage": "https://github.com/CAPHTECH/casegraph",
  "bugs": {
    "url": "https://github.com/CAPHTECH/casegraph/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CAPHTECH/casegraph.git",
    "directory": "packages/kernel"
  },
  "keywords": [
    "casegraph",
    "workflow",
    "graph",
    "deterministic",
    "planning"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ulid": "^2.4.0",
    "yaml": "^2.8.1"
  }
